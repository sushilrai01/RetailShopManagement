@page "/login"
@layout LoginLayout

<PageTitle>Login</PageTitle>
<div class="login-container">

    <div class="login-image">
        <img src="favicon.png" height="430px" width="391px" alt="Login Illustration" />
    </div>

    <div class="login-form">

        <div class="login-card">

            <h3>Retail Shop Management</h3>
            <p class="subtitle">Sign in to continue</p>

            @if (!string.IsNullOrEmpty(loginErrorMessage))
            {
                <div class="login-error">
                    <small>
                        @loginErrorMessage
                    </small>
                </div>
            }

            <EditForm Model="loginModel" OnValidSubmit="HandleLogin">

                <div class="form-group">
                    <label>Email</label>
                    <InputText class="form-control" @bind-Value="loginModel.Email" placeholder="Email or username" />
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <div class="password-wrapper">
                        <InputText type="@(showPassword ? "text" : "password")"
                                   class="form-control"
                                   @bind-Value="loginModel.Password"
                                   placeholder="Password" />
                        <button type="button" class="btn-eye" @onclick="() => showPassword = !showPassword">
                            <i class="fa @(showPassword ? "fa-eye-slash" : "fa-eye")" style="font-weight: lighter;"></i>
                        </button>
                    </div>
                </div>

                <div class="forgot-password">
                    <a href="/forgot-password">Forgot Password?</a>
                </div>

                <button class="btn-login">Login</button>

                <div class="register-link">
                    Don't have an account?
                    <a href="/register">Register</a>
                </div>
            </EditForm>

        </div>

    </div>

</div>

@code {

    private LoginModel loginModel = new();
    private string loginErrorMessage;
    private bool showPassword = false;

    private async Task HandleLogin()
    {
        await JsModalService.ConsoleLogAsync("Login clicked");

        if (string.IsNullOrWhiteSpace(loginModel.Email) && string.IsNullOrWhiteSpace(loginModel.Password))
        {
            loginErrorMessage = "Please enter email or password!";
            return;
        }
        if (loginModel.Email == "admin" && loginModel.Password == "admin")
        {
            NavigationManager.NavigateTo("/products");
        }
        else
        {
            loginErrorMessage = "The email or password you’ve entered is incorrect";
            StateHasChanged();
        }
    }

}
<style>
    .auth-wrapper {
        height: 100vh;
        background: linear-gradient(180deg,#142b66,#3b0b4f);
    }

    .login-container {
        display: flex;
        height: 100vh;
    }

    /* Image Side */

    .login-image {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
    }

        .login-image img {
            max-width: 70%;
        }

    .login-error {
        color: #d9534f; /* bootstrap danger red */
        font-weight: 600;
        margin-top: 10px;
        text-align: center;
    }

    .password-wrapper {
        position: relative;
    }

    .btn-eye {
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        border: none;
        background: transparent;
        cursor: pointer;
        font-size: 16px;
        padding: 0;
    }

    .forgot-password {
        text-align: right;
        margin-bottom: 10px;
    }

        .forgot-password a {
            font-size: 13px;
        }

    .register-link {
        text-align: center;
        margin-top: 15px;
        font-size: 14px;
    }
    /* Login Form Side */

    .login-form {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    /* Login Card */

    .login-card {
        width: 380px;
        background: white;
        padding: 35px;
        border-radius: 8px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.25);
    }

    .subtitle {
        color: #777;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-control {
        width: 100%;
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 4px;
    }

    .btn-login {
        width: 100%;
        padding: 10px;
        background: #1e8e3e;
        color: white;
        border: none;
        border-radius: 4px;
        font-weight: 600;
    }
</style>