@page "/loginOld"
@layout LoginLayout

@attribute [AllowAnonymous]

<PageTitle>Login</PageTitle>
<div class="login-container">

    <div class="login-image">
        <img src="favicon.png" height="430px" width="391px" alt="Login Illustration" />
    </div>

    <div class="login-form">

        <div class="login-card">

            <h3>Retail Shop Management</h3>
            <p class="subtitle">Sign in to continue</p>

            @if (!string.IsNullOrEmpty(loginErrorMessage))
            {
                <div class="login-error">
                    <small>
                        @loginErrorMessage
                    </small>
                </div>
            }

            <form method="post" action="/login">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="/products" />

                <div class="form-group">
                    <label>Email</label>
                    <InputText class="form-control" @bind-Value="LoginModel.Username" placeholder="Email or username" />
                </div>

                <div class="form-group">
                    <label>Password</label>
                    <div class="password-wrapper">
                        <InputText type="@(showPassword ? "text" : "password")"
                                   class="form-control"
                                   @bind-Value="LoginModel.Password"
                                   placeholder="Password" />
                        <button type="button" class="btn-eye" @onclick="() => showPassword = !showPassword">
                            <i class="fa @(showPassword ? "fa-eye-slash" : "fa-eye")" style="font-weight: lighter;"></i>
                        </button>
                    </div>
                </div>

                <div class="forgot-password">
                    <a href="/forgot-password">Forgot Password?</a>
                </div>

                <button type="submit" class="btn-login">Login</button>

                <div class="register-link">
                    Don't have an account?
                    <a href="/register/user">Register</a>
                </div>
            </form>

        </div>

    </div>

</div>

@code {
    // [CascadingParameter]
    // public HttpContext? HttpContext { get; set; }

    [SupplyParameterFromForm] public LoginModel LoginModel { get; set; } = new();

    private string loginErrorMessage;
    private bool showPassword = false;

    [Inject] private IAuthService AuthService { get; set; }

    private async Task HandleLogin()
    {
        await JsModalService.ConsoleLogAsync("Login clicked");

        if (string.IsNullOrWhiteSpace(LoginModel.Username) ||
            string.IsNullOrWhiteSpace(LoginModel.Password))
        {
            loginErrorMessage = "Please enter email or password!";
            return;
        }

        var response = await AuthService.LoginAsync(LoginModel.Username, LoginModel.Password);

        if (!response.IsSuccess)
        {
            loginErrorMessage = response.Message;
            ToastService.ShowError(response.Message);
            return;
        }

        // Navigate to dashboard
        NavigationManager.NavigateTo("/products", forceLoad: true);
        // }

    }

}

}
