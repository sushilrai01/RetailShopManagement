@if (InvoiceInfo != null)
{
    <div class="invoice-container">
        <div class="center-text">
            ===============================================<br />
            RETAIL SHOP INVOICE<br />
            ===============================================
        </div>

        <p class="invoice-info">
            Invoice No: <span>@InvoiceInfo.InvoiceNumber</span><br />
            Date: <span> @InvoiceInfo.InvoiceDate.ToString("dd MMMM yyyy")</span><br />
            Creditor: <span>@InvoiceInfo.CreditorName</span>
        </p>

        <div class="line"></div>

        <div class="bold">ITEMS</div>

        <div class="line"></div>

        <table>
            <thead>
                <tr>
                    <th>Description</th>
                    <th class="right">Qty</th>
                    <th class="right">Rate</th>
                    <th class="right">Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in InvoiceInfo.InvoiceItems)
                {
                    <tr>
                        <td>@item.Description</td>
                        <td class="right">@item.Quantity.ToString("0.000")</td>
                        <td class="right">@item.UnitPrice.ToString("0.00")</td>
                        <td class="right">@item.Subtotal.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="line"></div>

        <table>
            <tr>
                <td class="right bold">SubTotal</td>
                <td class="right">@InvoiceInfo.SubTotal.ToString("N2")</td>
            </tr>
            <tr>
                <td class="right bold">Tax (13% VAT)</td>
                <td class="right">@InvoiceInfo.TaxAmount.ToString("N2")</td>
            </tr>
            <tr>
                <td class="right bold">Discount</td>
                <td class="right">-@InvoiceInfo.DiscountAmount.ToString("N2")</td>
            </tr>
        </table>

        <div class="line"></div>

        <table>
            <tr>
                <td class="right bold">Total Amount</td>
                <td class="right bold">@InvoiceInfo.TotalAmount.ToString("N2")</td>
            </tr>
        </table>

        <div class="line"></div>

        <div class="bold">PAYMENTS</div>

        <p>
            @{
                var latestPaidDate = InvoiceInfo.LastModifiedOn ?? InvoiceInfo.InvoiceDate;
            }
            Paid on @latestPaidDate.ToString("dd/MM/yyyy")
            <span class="right" style="float:right">@InvoiceInfo.PaidAmount.ToString("N2")</span>
        </p>

        <div class="line"></div>

        <table>
            <tr>
                <td class="right bold">Balance Due</td>
                <td class="right bold">@InvoiceInfo.BalanceAmount.ToString("N2")</td>
            </tr>
        </table>

        <p class="pt-2">
            Remarks: @InvoiceInfo.Remarks
        </p>
        <div class="line"></div>

    </div>
}

@code {
 
    [Parameter] public InvoicesDto? InvoiceInfo { get; set; }
    
}