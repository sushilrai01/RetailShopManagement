@page "/user/create"

<PageTitle>New User</PageTitle>

<h3 class="subtitle">Create User Account</h3>

<EditForm Model="registerModel" OnValidSubmit="Save">
    <div class="row">
        <div class="form-group col-6">
            <label class="sn-required-field">Full Name</label>
            <InputText class="form-control"
                       @bind-Value="registerModel.FullName"
                       placeholder="Enter full name" />
        </div>

        <div class="form-group col-6">
            <label class="sn-required-field">Mobile No</label>
            <InputText class="form-control"
                       @bind-Value="registerModel.MobileNo"
                       placeholder="Enter mobile number" />
        </div>


        <div class="form-group col-6">
            <label class="sn-required-field">Address</label>
            <InputText class="form-control"
                       @bind-Value="registerModel.Address"
                       placeholder="Enter address" />
        </div>
        <div class="form-group col-6">
            <label class="sn-required-field">Email</label>
            <InputText class="form-control"
                       @bind-Value="registerModel.Email"
                       placeholder="Enter email" />
        </div>

        <div class="form-group col-6">
            <label class="sn-required-field">Username</label>
            <InputText class="form-control"
                       @bind-Value="registerModel.Username"
                       placeholder="Enter username" />
        </div>
    </div>

    <button class="btn btn-success">
        <i class="fas fa-check"></i>
        Create
    </button>
    <button type="button" class="btn btn-secondary" @onclick="@(() => NavigationManager.NavigateTo("/users"))">
        <i class="fas fa-times"></i> Cancel
    </button>

</EditForm>

@code {

    private RegisterModel registerModel = new();

    private string registerErrorMessage;

    [Inject] private IAuthService AuthService { get; set; }
    
    protected override async Task OnInitializedAsync()
    {
        if (!IsAdmin()) NavigationManager.NavigateTo("/access-denied");
    }

    private async Task Save()
    {
        if (!IsValidSubmit()) return;

        registerModel.IsActive = true;
        var response = await AuthService.RegisterUserAsync(registerModel);

        if (!response.IsSuccess)
        {
            ToastService.ShowError(response.Message);
            return;
        }

        ToastService.ShowSuccess(response.Message, 15000);

        NavigationManager.NavigateTo("/users");
    }

    private bool IsValidSubmit()
    {
        if (string.IsNullOrWhiteSpace(registerModel.FullName))
        {
            registerErrorMessage = "Fullname is required.";
            ToastService.ShowWarning(registerErrorMessage);
            return false;
        }
        else if (string.IsNullOrWhiteSpace(registerModel.MobileNo))
        {
            registerErrorMessage = "Mobile No. is required.";
            ToastService.ShowWarning(registerErrorMessage);
            return false;
        }
        else if (string.IsNullOrWhiteSpace(registerModel.Address))
        {
            registerErrorMessage = "Address is required.";
            ToastService.ShowWarning(registerErrorMessage);
            return false;
        }
        else if (string.IsNullOrWhiteSpace(registerModel.Email))
        {
            registerErrorMessage = "Email is required.";
            ToastService.ShowWarning(registerErrorMessage);
            return false;
        }

        return true;
    }

}