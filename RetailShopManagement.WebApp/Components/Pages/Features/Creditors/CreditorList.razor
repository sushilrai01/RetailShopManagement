@page "/Creditors" 

@attribute [StreamRendering]

<PageTitle>Creditors</PageTitle>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row align-items-end">

            <div class="col-2">
                <label class="form-label"></label>
                <button class="btn btn-success w-100"
                        @onclick="CreateNewCreditor">
                    <i class="fa-solid fa-plus me-2"></i>Create New
                </button>
            </div>
            
            <div class="col-2">
                <label class="form-label"></label>
                <button class="btn btn-warning"
                        @onclick="ShowMakePayment">
                    <i class="fa-solid fa-hand-holding-dollar"></i>
                    Make Payment
                </button>
            </div>
            <div class="col-2">
                <label class="form-label"></label>
                <button class="btn btn-secondary"
                        @onclick="LoadData">
                    <i class="fa-solid fa-arrow-rotate-right"></i>
                    Refresh
                </button>
            </div>
        </div>
    </div>
</div>

<div class="table-responsive table-overflow-y">
    @if (!creditorLists.Any())
    {
        <p>
            <em>No item found...</em>
        </p>
    }
    else
    {
        <table class="table table-borderless table-striped table-hover">
            <thead>
                <tr>
                    <th></th>
                    <th>Name</th>
                    <th>MobileNo</th>
                    <th>Email</th>
                    <th>Address</th>
                    <th>TotalAmount</th>
                    <th>PaidAmount</th>
                    <th>DueAmount</th>
                    <th>Status</th>

                    <th>CreatedOn</th>
                    <th>Actions</th>
                    <th>LastModifiedOn</th>
                    @* <th>LastModifiedBy</th> *@
                </tr>
            </thead>
            <tbody>
                @foreach (var item in creditorLists)
                {
                    <tr class="@(SelectedCreditorId == item.Id ? "selected-row" : "")"
                        @onclick="() => SelectCreditor(item)">
                        <td>
                            <i class="fa-solid @(expandedRows.Contains(item.Id) ? "fa-minus" : "fa-plus") fa-lg"
                                   title="Show Pay Slip"
                                   @onclick="() => TogglePaySlip(item.Id)"
                                   @onclick:stopPropagation="true"
                                   style="cursor:pointer;">
                            </i>
                        </td>

                        <td>@item.FullName</td>
                        <td>@item.MobileNo</td>
                        <td>@item.Email</td>
                        <td>@item.Address</td>
                        <td>@item.TotalAmount</td>
                        <td>@item.PaidAmount</td>
                        <td>@item.DueAmount</td>
                        <td>@item.Status</td>

                        <td>@item.CreatedOn</td>
                        <td class="cell-no-wrap">
                            <a class="btn btn-primary btn-sm"
                                   href="/invoices/creditor/@item.Id"
                                   target="_blank"
                                   @onclick:stopPropagation="true" title="Show Invoices">

                                <i class="fa-solid fa-file-invoice-dollar"></i>
                                Invoices
                            </a>

                            <button class="btn btn-info btn-sm m-1" @onclick="() => Edit(item)"
                                    @onclick:stopPropagation="true">
                                <i class="fa-regular fa-pen-to-square"></i>
                                Edit
                            </button>

                            @*  <button class="btn btn-danger my-1" @onclick="() => ShowCategoryDetails(item)"
                                    @onclick:stopPropagation="true">
                                <i class="fa-solid fa-trash-can"></i>
                                Delete
                            </button> *@
                        </td>

                        <td>@item.LastModifiedOn</td>
                        @* <td>@item.LastModifiedBy</td> *@
                    </tr>

                    @if (expandedRows.Contains(item.Id))
                    {
                        <tr class=" ">
                            <td colspan="13">
                                <!-- Payslip Details -->
                                <div class="toggle-div p-3">
                                    <em> <strong>Pay Slip History:</strong></em>

                                    @if (item.PaySlips.Any())
                                    {
                                        <div class="p-2">

                                            <!-- Header -->
                                            <div class="row  border-bottom pb-2 mb-2 bg-warning">
                                                <div class="col-4">Payment Date</div>
                                                <div class="col-4">Amount Paid</div>
                                                <div class="col-4">Remarks</div>
                                            </div>

                                            <!-- Data -->
                                            @foreach (var ps in item.PaySlips)
                                            {
                                                <div class="row border-bottom py-1">
                                                    <div class="col-4">@ps.PaymentDate</div>
                                                    <div class="col-4">@ps.AmountPaid</div>
                                                    <div class="col-4">@ps.Remarks</div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <p>No payslips available.</p>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    }


</div>

<hr />
<p class="list-counter-margin">
    <em>
        <small class="fw-bold">
            Total Records = @TotalRecords
        </small>
    </em>
</p>

<CreatePaySlip @ref="refCreatePaySlip" OnSubmitCallback="SubmitCallbackHandler" />

@code {
    private List<CreditorDto> creditorLists = new();
    private CreditorDto? SelectedCreditor { get; set; }
    private DateTime? StartDate { get; set; } = DateTime.Now.AddDays(-14);
    private DateTime? EndDate { get; set; } = DateTime.Now;
    private int TotalRecords { get; set; }
    private HashSet<Guid> expandedRows = new HashSet<Guid>();

    private Guid? SelectedCreditorId { get; set; }
    private CreatePaySlip refCreatePaySlip;

    [Inject] private ICreditorService CreditorService { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        StateHasChanged();
    }


    private async Task LoadData()
    {

        var response = await CreditorService.GetCreditorsAsync();
        if (!response.IsSuccess)
        {
            ToastService.ShowError(response.Message);
            return;
        }

        ToastService.ShowSuccess(response.Message);
        creditorLists = response.Data.ToList();
        TotalRecords = creditorLists.Count();
        SelectedCreditor = null;

        StateHasChanged();
    }

    private void TogglePaySlip(Guid id)
    {
        if (!expandedRows.Add(id))
            expandedRows.Remove(id);
    }

    private async Task Filter()
    {
        await LoadData();

    }

    private void CreateNewCreditor()
    {
        NavigationManager.NavigateTo("/creditor/create");
    }

    private void Edit(CreditorDto? selectedCreditor)
    {
        if (selectedCreditor is null) return;
        NavigationManager.NavigateTo($"/creditor/edit/{selectedCreditor.Id}");
    }
    
    
    private void SelectCreditor(CreditorDto? selectedCreditor)
    {
        if (selectedCreditor is null) return;
        SelectedCreditor = selectedCreditor;
        SelectedCreditorId = selectedCreditor.Id;

        StateHasChanged();
    }
    
    private void ShowMakePayment()
    {
        if (SelectedCreditorId.Empty())
        {
            ToastService.ShowInfo("Please select creditor first by clicking row.");
            return;
        }
        if (SelectedCreditor is null) return;

        if (SelectedCreditor.DueAmount == 0)
        {
            ToastService.ShowWarning("Cannot pay for Due amount is 0.");
            return;
        }
        var paySlipForm = new PaySlipDto()
        {
            CreditorId = SelectedCreditorId!.Value,
            CreditorName = SelectedCreditor!.FullName,
            DueAmount = SelectedCreditor.DueAmount
        };

        refCreatePaySlip.ShowForm(paySlipForm, SelectedCreditor.InvoiceLists);

    }
    
    private async Task SubmitCallbackHandler(bool isActionSubmit)
    {
        if (isActionSubmit)
        {
            await LoadData();
        }
    }

}