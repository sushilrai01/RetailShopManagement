@page "/purchase-history"

@attribute [StreamRendering]

<PageTitle>Purchase History</PageTitle>

<h3 class="subtitle"> Purchase History</h3>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row align-items-end">
            
            <div class="col-3">
                <label class="sn-required-field">Supplier</label>
                <InputSelect class="form-control" @bind-Value="selectedSupplierId" @bind-Value:after="LoadData">

                    @foreach (var creditor in SupplierDropDownFields)
                    {
                        <option value="@creditor.Value">
                            @creditor.Text
                        </option>
                    }
                </InputSelect>
            </div>

            <div class="col-md-4">
                <DateRangePicker StartDate="StartDate"
                                 EndDate="EndDate"
                                 OnDateRangeChanged="OnDateRangeChangeEventHandler" />
            </div>
            
            <div class="col-md-3">
                <label class="form-label">Report Timeline</label>
                <InputSelect class="form-control" @bind-Value="selectedTimeLine" @bind-Value:after="OnReportTimelineChange">
                    @foreach (var category in ReportTimelineFields)
                    {
                        <option value="@category.Value">
                            @category.Text
                        </option>
                    }
                </InputSelect>
            </div>
            
            <div class="col-md-2">
                <label class="form-label">Order Status</label>
                <select class="form-control" @bind-Value="selectedStatus" @bind-Value:after="LoadData">
                    @foreach (var category in invoiceStatusFields)
                    {
                        <option value="@category.Value">
                            @category.Text
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label"></label>
                <button class="btn btn-secondary w-100"
                        @onclick="Filter">
                    <i class="fa-solid fa-magnifying-glass me-2"></i>
                    Filter
                </button>
            </div>

        </div>
    </div>
</div>

<div class="table-responsive table-overflow-y">
    @if (ProductPurchaseInfoDto == null || !ProductPurchaseInfoDto.PurchaseItems.Any())
    {
        <p>
            <em>No item found...</em>
        </p>
    }
    else
    {
        <table class="table table-borderless table-striped table-hover">
            <thead>
                <tr class="no-wrap-head">
                    <th @onclick="@(() => OrderRecords("InvoiceNumber"))" style="cursor: pointer;">
                        Invoice Number
                        <i class="fa-solid fa-sort fa-sm"></i>
                    </th>
                    <th @onclick="@(() => OrderRecords("Description"))" style="cursor: pointer;">
                        Description
                        <i class="fa-solid fa-sort fa-sm"></i>
                    </th>
                    <th @onclick="@(() => OrderRecords("SupplierName"))" style="cursor: pointer;">
                        Supplier Name
                        <i class="fa-solid fa-sort fa-sm"></i>
                    </th>
                    <th @onclick="@(() => OrderRecords("Quantity"))" style="cursor: pointer;">
                        Qty
                        <i class="fa-solid fa-sort fa-sm"></i>
                    </th>
                    <th>Unit Price</th>
                   
                    <th @onclick="@(() => OrderRecords("SubTotal"))" style="cursor: pointer;">
                        SubTotal
                        <i class="fa-solid fa-sort fa-sm"></i>
                    </th>
                    
                    <th @onclick="@(() => OrderRecords("CreatedOn"))" style="cursor: pointer;">
                        CreatedOn
                        <i class="fa-solid fa-sort fa-sm"></i>
                    </th>
                    <th> Remarks</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in ProductPurchaseInfoDto.PurchaseItems)
                {
                    <tr>
                        <td>@item.InvoiceNumber</td>
                        <td>@item.Description</td>
                        <td>@item.SupplierName</td>
                        <td>@item.Quantity</td>
                        <td>@item.UnitPrice</td>
                        <td>@item.SubTotal</td>
                        <td>@item.CreatedOn</td>
                        <td>@item.Notes</td>
                    </tr>
                }
            </tbody>
            <tfoot class="sticky-footer">
                <tr class="table-active fw-bold">
                    <td colspan="3">Grand Total:</td>
                    <td>@ProductPurchaseInfoDto.TotalQuantity</td>
                    <td> </td>
                    <td>@ProductPurchaseInfoDto.GrandTotal</td>
                    <td colspan="2"> </td>
                </tr>
            </tfoot>
        </table>
    }

</div>

<hr />
<p class="list-counter-margin">
    <em>
        <small>
            Total Records = @TotalRecords
        </small>
    </em>
</p>

@code {
    private ProductPurchaseInfoDto ProductPurchaseInfoDto { get; set; }

    private bool IsAscending { get; set; } = true;

    private string selectedTimeLine { get; set; }
    private string selectedStatus { get; set; }
    private int selectedSupplierId { get; set; }

    private IList<DropDownField> invoiceStatusFields { get; set; } = PaymentStatus.GetOrderStatus();
    private IList<DropDownField> ReportTimelineFields { get; set; } = ReportTypeConst.GetTimelineFields();
    private IList<IntDropDownField> SupplierDropDownFields { get; set; } = new List<IntDropDownField>();

    private DateTime? StartDate { get; set; } = DateTime.Now.AddDays(-14);
    private DateTime? EndDate { get; set; } = DateTime.Now;

    private int TotalRecords { get; set; }

    [Inject] private IPurchaseService PurchaseService { get; set; }

    protected override async Task OnInitializedAsync()
    {
        SupplierDropDownFields = await SuppliersFieldList;

        await LoadData();
        StateHasChanged();
    }

    private async Task LoadData()
    {
        try
        {
            LoadingService.Show();

            var response = await PurchaseService.GetProductPurchaseHistoryAsync(supplierId: selectedSupplierId, orderStatus: selectedStatus, fromDate: StartDate, toDate: EndDate);
            if (!response.IsSuccess)
            {
                ToastService.ShowError(response.Message);
                return;
            }

            ToastService.ShowSuccess(response.Message);

            ProductPurchaseInfoDto = response.Data;
            TotalRecords = ProductPurchaseInfoDto.PurchaseItems.Count();

            StateHasChanged();
        }
        finally
        {
            LoadingService.Hide();
        }
    }

    private async Task Filter()
    {
        await LoadData();

    }

    private async Task OnDateRangeChangeEventHandler(DateRangePicker.DateRange dateRange)
    {
        selectedTimeLine = string.Empty;
        StartDate = dateRange.StartDate;
        EndDate = dateRange.EndDate;

        await LoadData();
    }

    private void OnReportTimelineChange()
    {
        var today = DateTime.Now.Date;

        if (selectedTimeLine == ReportTypeConst.Daily)
        {
            StartDate = today;
            EndDate = today.AddDays(1);
        }
        else if (selectedTimeLine == ReportTypeConst.Weekly)
        {
            StartDate = today.AddDays(-7);
            EndDate = today.AddDays(1);
        }
        else if (selectedTimeLine == ReportTypeConst.Monthly)
        {
            StartDate = today.AddDays(-30);
            EndDate = today.AddDays(1);
        }
    }
    
    private void OrderRecords(string? orderParm = null)
    {
        var orderList = ProductPurchaseInfoDto.PurchaseItems.AsQueryable();
        ProductPurchaseInfoDto.PurchaseItems = orderParm switch
        {
            "InvoiceNumber" => IsAscending
                ? orderList.OrderBy(x => x.InvoiceNumber).ToList()
                : orderList.OrderByDescending(x => x.InvoiceNumber).ToList(),
            "Description" => IsAscending
                ? orderList.OrderBy(x => x.Description).ToList()
                : orderList.OrderByDescending(x => x.Description).ToList(),
            "SupplierName" => IsAscending
                ? orderList.OrderBy(x => x.SupplierName).ToList()
                : orderList.OrderByDescending(x => x.SupplierName).ToList(),
            "Quantity" => IsAscending
                ? orderList.OrderBy(x => x.Quantity).ToList()
                : orderList.OrderByDescending(x => x.Quantity).ToList(),
            "SubTotal" => IsAscending
                ? orderList.OrderBy(x => x.SubTotal).ToList()
                : orderList.OrderByDescending(x => x.SubTotal).ToList(),
            "CreatedOn" => IsAscending
                ? orderList.OrderBy(x => x.CreatedOn).ToList()
                : orderList.OrderByDescending(x => x.CreatedOn).ToList(),
         
            _ => orderList.ToList()
        };

        IsAscending = !IsAscending;

        StateHasChanged();
    }
}