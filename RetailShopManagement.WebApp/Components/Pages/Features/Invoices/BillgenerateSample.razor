@page "/bill-generate-sample"

<h3>Retail Shop Invoice</h3>

<style>
    .invoice-container {
        max-width: 700px;
        margin: auto;
        margin-bottom: 50px;
        font-family: monospace;
        background: #fff;
        padding: 20px;
        border: 1px solid #ccc;
    }

    .center-text {
        text-align: center;
        font-weight: bold;
    }

    .line {
        border-top: 1px dashed #000;
        margin: 10px 0;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th, td {
        padding: 4px;
        text-align: left;
    }

    .right {
        text-align: right;
    }

    .bold {
        font-weight: bold;
    }
</style>
<div class="invoice-container">
    <div class="center-text">
        ===============================================<br />
        RETAIL SHOP INVOICE<br />
        ===============================================
    </div>

    <p>
        Invoice No: @InvoiceNo<br />
        Date: @Date.ToString("dd MMMM yyyy")<br />
        Creditor: @CreditorName
    </p>

    <div class="line"></div>

    <div class="bold">ITEMS</div>

    <div class="line"></div>

    <table>
        <thead>
            <tr>
                <th>Description</th>
                <th class="right">Qty</th>
                <th class="right">Rate</th>
                <th class="right">Amount</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Items)
            {
                <tr>
                    <td>@item.Description</td>
                    <td class="right">@item.Qty.ToString("0.000")</td>
                    <td class="right">@item.Rate.ToString("0.00")</td>
                    <td class="right">@item.Amount.ToString("0.00")</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="line"></div>

    <table>
        <tr>
            <td class="right bold">SubTotal</td>
            <td class="right">@SubTotal.ToString("N2")</td>
        </tr>
        <tr>
            <td class="right bold">Tax (13% VAT)</td>
            <td class="right">@TaxAmount.ToString("N2")</td>
        </tr>
        <tr>
            <td class="right bold">Discount</td>
            <td class="right">-@Discount.ToString("N2")</td>
        </tr>
    </table>

    <div class="line"></div>

    <table>
        <tr>
            <td class="right bold">Total Amount</td>
            <td class="right bold">@TotalAmount.ToString("N2")</td>
        </tr>
    </table>

    <div class="line"></div>

    <div class="bold">PAYMENTS</div>

    <p>
        Paid on @Date.ToString("dd/MM/yyyy")
        <span class="right" style="float:right">@PaidAmount.ToString("N2")</span>
    </p>

    <div class="line"></div>

    <table>
        <tr>
            <td class="right bold">Balance Due</td>
            <td class="right bold">@BalanceAmount.ToString("N2")</td>
        </tr>
    </table>

    <div class="center-text">
        ===============================================
    </div>
</div>

@code {
    private string InvoiceNo = "INV-2024-001";
    private DateTime Date = DateTime.Now;
    private string CreditorName = "ABC Suppliers Pvt. Ltd.";

    private List<InvoiceItem> Items = new()
    {
        new() { Description = "Rice (kg)", Qty = 2.5m, Rate = 150.50m },
        new() { Description = "Oil (ltr)", Qty = 5m, Rate = 280.00m },
        new() { Description = "Oil (ltr)", Qty = 5m, Rate = 280.00m },
        new() { Description = "Oil (ltr)", Qty = 5m, Rate = 280.00m },
        new() { Description = "Oil (ltr)", Qty = 5m, Rate = 280.00m },
        new() { Description = "Oil (ltr)", Qty = 5m, Rate = 280.00m },
        new() { Description = "Sugar (kg)", Qty = 10m, Rate = 85.50m }
    };

    private decimal SubTotal => Items.Sum(x => x.Amount);
    private decimal TaxAmount => SubTotal * 0.13m;
    private decimal Discount = 100m;
    private decimal TotalAmount => SubTotal + TaxAmount - Discount;
    private decimal PaidAmount = 2000m;
    private decimal BalanceAmount => TotalAmount - PaidAmount;

    public class InvoiceItem
    {
        public string Description { get; set; } = string.Empty;
        public decimal Qty { get; set; }
        public decimal Rate { get; set; }
        public decimal Amount => Qty * Rate;
    }
}
