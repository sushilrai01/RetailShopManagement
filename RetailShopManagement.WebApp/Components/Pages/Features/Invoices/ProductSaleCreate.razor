@page "/product/sale-create"
@using RetailShopManagement.Application.Validators
@using RetailShopManagement.Domain.Constants

<PageTitle>Product Sale</PageTitle>

<div class="p-3">

    <div class="row">

        <div class="form-group-x col-6">
            <label class="sn-required-field">Creditor</label>
            <InputSelect class="form-control" @bind-Value="invoiceForm.CreditorId">

                @foreach (var creditor in CreditorDropDownFields)
                {
                    <option value="@creditor.Value">
                        @creditor.Text
                    </option>
                }
            </InputSelect>
        </div>

        <div class="form-group-x col-6">
            <label class="sn-required-field">Invoice Date</label>
            <InputDate class="form-control"
                       @bind-Value="invoiceForm.InvoiceDate" />
        </div>
    </div>

    <hr />

    <!-- Columns Header -->
    <div class="row fw-bold">
        <div class="form-group-x col-5">
            <label class="sn-required-field">Description</label>
        </div>
        <div class="form-group-x col-2">
            <label class="sn-required-field">Qty</label>
        </div>
        <div class="form-group-x col-2">
            <label class="sn-required-field">Rate</label>
        </div>
        <div class="form-group-x col-2">
            <label class="sn-required-field">Amount</label>
        </div>
        <div class="form-group-x col-1">
        </div>
    </div>

    <!-- Rows Invoice Items -->
    @for (int i = 0; i < Count; i++)
    {
        var localCounter = i;

        <div class="row">

            <div class="form-group-x col-5">
                <div class="row">
                    <div class="form-group-x col-6">
                        <InputText class="form-control"
                                   @bind-Value="invoiceForm.InvoiceItems[localCounter].ProductName"
                                   placeholder="Enter Product Name" />

                    </div>
                    <div class="form-group-x col-6">
                        <InputSelect class="form-control" @bind-Value="invoiceForm.InvoiceItems[localCounter].Unit">
                            @foreach (var unit in UnitsFields)
                            {
                                <option value="@unit.Value">@unit.Text</option>
                            }
                        </InputSelect>
                    </div>
                </div>
            </div>

            <div class="form-group-x col-2">
                <InputNumber class="form-control" @bind-Value="invoiceForm.InvoiceItems[localCounter].Quantity" />
            </div>

            <div class="form-group-x col-2">
                <InputNumber class="form-control" @bind-Value="invoiceForm.InvoiceItems[localCounter].UnitPrice" />
            </div>

            <div class="form-group-x col-2">
                <InputNumber class="form-control" @bind-Value="invoiceForm.InvoiceItems[localCounter].Subtotal" />
            </div>
            <div class="  col-1">
                @if (localCounter == Count - 1)
                {
                    <button type="button" class="btn btn-warning" @onclick="AddNewRow">
                        <i class="fas fa-plus"></i>
                    </button>
                }
                else
                {
                    <button type="button" class="btn btn-warning" @onclick="() => RemoveRow(localCounter)">
                        <i class="fas fa-minus"></i>
                    </button>
                }
            </div>
        </div>
    }

    <hr />

    <!-- Total Calculation -->

    <div class="row">
        <div class="form-group-x col-3">
        </div>
        <div class="form-group-x col-6">
            <label class="sn-required-field">Sub Total</label>
        </div>

        <div class="form-group-x col-2">
            <InputNumber class="form-control" @bind-Value="invoiceForm.SubTotal" />
        </div>

    </div>

    <div class="row">
        <div class="form-group-x col-3">
        </div>
        <div class="form-group-x col-6">
            <label class="sn-required-field">Tax (13% VAT)</label>
        </div>

        <div class="form-group-x col-2">
            <InputNumber class="form-control" @bind-Value="invoiceForm.TaxAmount" />
        </div>

    </div>

    <div class="row">
        <div class="form-group-x col-3">
        </div>
        <div class="form-group-x col-3">
            <label class="sn-required-field">Discount</label>
        </div>
        <div class="form-group-x col-3">
            <InputNumber class="form-control" @bind-Value="invoiceForm.DiscountPercent" placeholder="" />
        </div>

        <div class="form-group-x col-2">
            <InputNumber class="form-control" @bind-Value="invoiceForm.DiscountAmount" />
        </div>

    </div>

    <div class="row">
        <div class="form-group-x col-3">
        </div>
        <div class="form-group-x col-6">
            <label class="sn-required-field">Discount</label>
        </div>
        <div class="form-group-x col-2">
            <InputNumber class="form-control" @bind-Value="invoiceForm.TotalAmount" />
        </div>

    </div>

    <div class="row">
        <div class="form-group-x col-3">
        </div>
        <div class="form-group-x col-6">
            <label class="sn-required-field">Paid Amount</label>
        </div>
        <div class="form-group-x col-2">
            <InputNumber class="form-control" @bind-Value="invoiceForm.PaidAmount" />
        </div>

    </div>

    <div class="row">
        <div class="form-group-x col-3">
        </div>
        <div class="form-group-x col-6">
            <label class="sn-required-field">Balance Amount</label>
        </div>
        <div class="form-group-x col-2">
            @{
                invoiceForm.BalanceAmount = invoiceForm.TotalAmount - invoiceForm.PaidAmount;
            }


        </div>

    </div>


    <!-- Submit -->
    <div class="row justify-content-end">
        <div class="col-auto">
            <button class="btn btn-success me-2" @onclick="Save">
                <i class="fas fa-check"></i>
                Generate Invoice
            </button>
            <button type="button" class="btn btn-dark" @onclick="@(() => NavigationManager.NavigateTo("/creditors"))">
                <i class="fas fa-times"></i> Cancel
            </button>
        </div>
    </div>
</div>

@code {
    private InvoicesDto invoiceForm = new();
    private IList<NullableGuidDropDownField> CreditorDropDownFields { get; set; } = new List<NullableGuidDropDownField>();

    private IList<DropDownField> UnitsFields { get; set; } = UnitsConst.UnitsFields;

    private int Count;


    [Inject] private ICreditorService CreditorService { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await Initialize();
        StateHasChanged();
    }

    private async Task Initialize()
    {
        CreditorDropDownFields = await CreditorsFieldList;

        invoiceForm.InvoiceItems = new List<ProductSalesDto>()
        {
            new(),
        };

        Count++;

    }

    private async Task Save()
    {
        if (!ValidateFormOnSave()) return;

        var response = await CreditorService.CreateCreditorAsync(new CreditorDto());

        if (!response.IsSuccess)
        {
            ToastService.ShowError(response.Message);
            return;
        }

        ToastService.ShowSuccess(response.Message, 15000);

        NavigationManager.NavigateTo("/creditors");
    }

    #region Row management
    private void AddNewRow()
    {
        if (!Validate(invoiceForm.InvoiceItems[Count - 1])) return;
        Count += 1;
        invoiceForm.InvoiceItems.Add(new ProductSalesDto());

        StateHasChanged();
    }

    private async Task RemoveRow(int index)
    {
        var isConfirmed = await JsModalService.ConfirmAsync("Are you sure you want to delete this row?");

        if (!isConfirmed) return;

        RemoveConfirmed(index);
    }

    private void RemoveConfirmed(int index)
    {
        invoiceForm.InvoiceItems.RemoveAt(index);
        Count--;

        StateHasChanged();
    }

    #endregion

    private bool Validate(ProductSalesDto productSales)
    {
        var validator = new ProductSalesValidator();
        var validationResult = validator.Validate(productSales);

        if (!validationResult.IsValid)
        {
            var errors = string.Join(Environment.NewLine, validationResult.Errors.Select(x => x));

            ToastService.ShowError(errors);
            return false;
        }

        return true;
    }

    private bool ValidateFormOnSave()
    {

        if (invoiceForm.InvoiceDate == DateTime.MinValue)
        {
            ToastService.ShowInfo("Please enter Invoice Date.");
            return false;
        }

        if (!Validate(invoiceForm.InvoiceItems[Count - 1])) return false;

        return true;
    }

}
