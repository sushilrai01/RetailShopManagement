@page "/invoice/save-pdf/{InvoiceId:guid}"

<PageTitle>Save Invoice Pdf</PageTitle>


<a class="btn btn-success btn-sm mb-2"
   href="/invoices"
   title="Go Back"
   @onclick:stopPropagation="true">
    <i class="fa-solid fa-arrow-left"></i> Invoices List
</a>  
<h3 class="subtitle">Retail Shop Invoice</h3>

<InvoiceComponent InvoiceInfo="InvoiceInfo" />

@code {
    [Parameter] public Guid InvoiceId { get; set; }

    public InvoicesDto InvoiceInfo { get; set; }

    [Inject] private IInvoiceService InvoiceService { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            LoadingService.Show();
            
            var response = await InvoiceService.GetInvoiceByIdAsync(InvoiceId);

            if (!response.IsSuccess)
            {
                ToastService.ShowError(response.Message);
                return;
            }

            ToastService.ShowSuccess(response.Message, 3000);

            InvoiceInfo = response.Data;
            StateHasChanged();
        }
        finally
        {
            LoadingService.Hide();
        }
    }

}
