<div class="not-found-container">
    <div class="not-found-content">
        <h1 class="display-1">404</h1>
        <h2 class="text-secondary">Oops! Page not found</h2>
        <p class="text-muted">
            Sorry, the page you're looking for doesn't exist. Please check the URL or go back to the homepage.
        </p>

        @if (!string.IsNullOrEmpty(RequestedPath) && RequestedPath != "unknown")
        {
            <div class="requested-path-box">
                <small class="text-danger fw-semibold">Requested URL:</small>
                <code class="d-block mt-1">/@RequestedPath</code>
            </div>
        }
        <a href="/" class="btn btn-primary btn-lg mt-4">Go to Homepage</a>
    </div>
</div>

@code {
    [Parameter]
    public string RequestedPath { get; set; } = string.Empty;
}
<style>
    ﻿.not-found-container {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 80vh;  
        background-color: transparent;
    }

    .not-found-content {
        text-align: center;
        padding: 2rem;
        background-color: rgba(255, 255, 255, 0.9);  
        border-radius: 10px;                         
        box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1); 
    }

        .not-found-content h1 {
            font-size: 6rem;
            font-weight: bold;
            color: #dc3545; 
            margin-bottom: 0.5rem;
        }

        .not-found-content h2 {
            font-size: 2rem;
            font-weight: 500;
            margin-bottom: 1rem;
        }

        .not-found-content p {
            font-size: 1rem;
            color: #6c757d;
        }

        .not-found-content .btn {
            font-size: 1rem;
            padding: 0.75rem 1.5rem;
        }

    .requested-path-box {
        background-color: #fff3cd;
        border: 1px solid #ffc107;
        border-radius: 8px;
        padding: 1rem;
        margin: 1.5rem 0;
        text-align: left;
    }

        .requested-path-box code {
            background-color: #fff;
            color: #dc3545;
            padding: 0.5rem;
            border-radius: 4px;
            font-size: 0.9rem;
            word-break: break-all;
            border: 1px solid #dee2e6;
        }
</style>